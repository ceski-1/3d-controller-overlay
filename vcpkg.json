{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "dependencies": [
    {
      "name": "glad",
      "default-features": false,
      "features": [
        "gl-api-33",
        "loader"
      ]
    },
    "glfw3",
    "glm",
    {
      "name": "imgui",
      "default-features": false,
      "features": [
        "glfw-binding",
        "opengl3-binding"
      ]
    },
    "libusb",
    {
      "name": "sdl3",
      "default-features": false,
      "features": [
        {
          "name": "dbus",
          "platform": "linux"
        },
        {
          "name": "ibus",
          "platform": "linux"
        },
        "libusb",
        {
          "name": "wayland",
          "platform": "linux"
        },
        {
          "name": "x11",
          "platform": "linux"
        }
      ]
    },
    "stb"
  ]
}
